{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Synapse",
  "version": "3.0.2",
  "identifier": "com.synapse.desktop",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Synapse",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "backgroundColor": "#060414"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "deb", "rpm", "appimage"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "Synape.desktop",
        "files": {
          "/usr/share/metainfo/com.Synape.desktop.metainfo.xml": "com.Synape.desktop.metainfo.xml"
        }
      },
      "rpm": {
        "desktopTemplate": "Synape.desktop",
        "files": {
          "/usr/share/metainfo/com.Synape.desktop.metainfo.xml": "com.Synape.desktop.metainfo.xml"
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ansxuman/Synape/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUxNTMyMTA3Nzc0NzA3NzUKUldSMUIwZDNCeUZUVVhEdkRHdk1qd0NmS2hybWZEWXYwQWxoVjh3STF5KzVkNzY1aTlxelgvMlQK"
    },
    "deep-link": {
      "desktop": {
        "schemes": ["Synape"]
      }
    }
  }
}
