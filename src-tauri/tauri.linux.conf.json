{
  "app": {
    "windows": [
      {
        "title": "Clauge",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": false,
        "transparent": true
      }
    ]
  },
  "bundle": {
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "libssl3",
          "libsecret-1-0",
          "libdbus-1-3",
          "libnotify4"
        ]
      },
      "rpm": {
        "epoch": 0,
        "release": "1",
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "openssl-libs",
          "libsecret",
          "dbus-libs",
          "libnotify"
        ]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
